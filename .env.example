DATABASE_URL=postgres://ooh_app:ooh_app_password@localhost:5432/ooh_market
TEST_DATABASE_URL=postgres://ooh_app:ooh_app_password@localhost:5432/ooh_market_test
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_SSL=false
# Production RDS should use DATABASE_SSL=true and certificate verification.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Store the AWS RDS CA bundle as Base64 in Secrets Manager when required.
DATABASE_SSL_CA_BASE64=
BOOTSTRAP_ADMIN_TOKEN=change-me-before-production
APP_ORIGIN=http://localhost:3000
PUBLIC_API_BASE64_MAX_BYTES=20971520
MEDIA_STORAGE_PROVIDER=local
MEDIA_BUCKET=
MEDIA_KEY_PREFIX=
AWS_REGION=ca-central-1
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
